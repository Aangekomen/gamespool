{
    "name": "aangekomen/flexicomp",
    "description": "FlexiComp — flexibel score- en competitiesysteem voor barspellen (pool, darts, etc.)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-gd": "*",
        "endroid/qr-code": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "GamesPool\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
